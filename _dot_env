# The server requires a .env file in its working directory
# this is a template
# for true local development you can keep the SECRET_KEY, but for an externally accessible instance YOU SHOULD NOT.
#
# here the database file will be placed
DATABASE_URL=/some/writable/path/database.sqlite
# use localhost for 127.0.0.1 if you dont want to acess the server from another machine
BINDING_HOST=andreass-mini
# well, some number
PORT=8080
# where the jukebox_fuel repo is checked out, plus ./songs
SONGS_DIR=/Users/andreassliwka/src/jukebox_fuel/songs
# Since the server does not know if its placed between an reverse procy doing TSL, we specify this here
HTTP_ONLY=true
# BASE64 encoded secret, at least 512bytes long, for securing the session cookie
SECRET_
# to generate QR Codes, the server must know its external URL
BASE_URL=http://andreass-mini:8080/
